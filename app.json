{
  "expo": {
    "name": "GLAPP",
    "slug": "GLAPP",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/gl.jpeg",
    "scheme": "GLAPP",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.globalinkmarketplace.app",
      "statusBarHidden": false,
      "statusBarStyle": "dark-content",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Globalink needs access to your photo library to let you upload a profile picture.",
        "NSCameraUsageDescription": "Globalink needs camera access to let you take a profile picture.",
        "NSLocationWhenInUseUsageDescription": "Globalink uses your location to show nearby stores and services.",
        "NSNotificationsUsageDescription": "Globalink sends notifications for order updates and promotions."
      }
    },
    "android": {
      "package": "com.globalinkmarketplace.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/gl.jpeg",
        "backgroundColor": "#FFFFFF"
      },
      "permissions": [
        "INTERNET"
      ],
      "blockedPermissions": [
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ],
      "statusBar": {
        "backgroundColor": "#FFFFFF",
        "translucent": false,
        "barStyle": "dark-content"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "GLAPP",
              "host": "*",
              "pathPrefix": "/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-web-browser",
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d83bbee6-83a0-44eb-9111-1f440548640f"
      }
    },
    "owner": "babagana1"
  }
}